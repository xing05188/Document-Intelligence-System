{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/doc-intel/extraction-result.schema.json",
  "title": "ExtractionResult",
  "description": "B 组抽取结果，与 integration-contract-v1.md 一致",
  "type": "object",
  "required": ["schema_version", "task_id", "fields"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0"]
    },
    "task_id": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "properties": {
        "file_name": { "type": "string" },
        "file_hash": { "type": "string" },
        "mime_type": { "type": "string" },
        "page_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "fields": {
      "type": "array",
      "items": { "$ref": "#/$defs/fieldItem" }
    },
    "extras": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false,
  "$defs": {
    "fieldItem": {
      "type": "object",
      "required": ["key", "value"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "value": {
          "type": ["string", "number", "boolean", "object", "array", "null"]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence": {
          "type": "object",
          "properties": {
            "page": { "type": "integer", "minimum": 1 },
            "paragraph_index": { "type": "integer", "minimum": 0 },
            "quote": { "type": "string" },
            "sheet": { "type": "string" },
            "cell": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  }
}
