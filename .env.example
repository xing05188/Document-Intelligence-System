LLM_PROVIDER=zhipu
LLM_MODEL=glm-4-flash
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
ZHIPU_API_KEY=
DEEPSEEK_API_KEY=

# -----------------------------
# PostgreSQL (Azure Database for PostgreSQL)
# -----------------------------
DB_ENABLED=true
DB_HOST=document.postgres.database.azure.com
DB_PORT=5432
DB_NAME=postgres
# Azure PostgreSQL 用户名通常为: <username>@document
DB_USER=your_username@document
DB_PASSWORD=your_password
DB_SSLMODE=require

# 也可直接使用连接串（二选一，优先级更高）
# DATABASE_URL=postgresql://your_username%40document:your_password@document.postgres.database.azure.com:5432/postgres?sslmode=require

# -----------------------------
# Azure Blob Storage
# -----------------------------
# STORAGE_PROVIDER=azure_blob
# STORAGE_ENABLED=true
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_account;AccountKey=your_key;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER_NAME=document
# AZURE_STORAGE_BLOB_PREFIX=sessions

# -----------------------------
# Supabase Storage (二选一：Azure Blob 或 Supabase)
# -----------------------------
# STORAGE_PROVIDER=supabase
# STORAGE_ENABLED=true
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key
# SUPABASE_STORAGE_BUCKET=document
# SUPABASE_STORAGE_PREFIX=sessions