# LLM_PROVIDER=zhipu
# LLM_MODEL=glm-4-flash
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
ZHIPU_API_KEY=
DEEPSEEK_API_KEY=

# -----------------------------
# PostgreSQL (Azure Database for PostgreSQL)
# -----------------------------
DB_ENABLED=true
DATABASE_URL=postgresql://your_username%40document:your_password@document.postgres.database.azure.com:5432/postgres?sslmode=require
DB_SSLMODE=require

# -----------------------------
# Supabase Storage (二选一：Azure Blob 或 Supabase)
# -----------------------------
STORAGE_PROVIDER=supabase
STORAGE_ENABLED=true
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=document
SUPABASE_STORAGE_PREFIX=sessions