# 复制为 .env 后填写。数据库（Supabase：在 Project Settings → Database 复制 Connection string）

# --- PostgreSQL / Supabase ---
DB_ENABLED=false

# 方式一（推荐）：完整 URI，密码已含在串中
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# SUPABASE_DB_URL= 与 DATABASE_URL 二选一即可

# 方式二：分段配置（本地 Postgres 等）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=doc_intel
# DB_USER=postgres
# DB_PASSWORD=

# 云库通常需要：require；若 URI 已带 ?sslmode=require 可省略
# DB_SSLMODE=require

# 连接池
# DB_POOL_MAX=10
